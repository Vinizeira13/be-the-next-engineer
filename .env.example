# =============================================================================
# AI Mentor — uses Vercel AI Gateway, NOT direct Anthropic.
# Two ways to authenticate (pick one):
# =============================================================================

# OPTION A: OIDC (recommended on Vercel)
#   1. `vercel link` (links this repo to a Vercel project)
#   2. `vercel env pull .env.local` (writes VERCEL_OIDC_TOKEN, valid ~24h)
#   3. Re-run vercel env pull when token expires
#
# This is automatic when deployed on Vercel — token refreshes itself.

# OPTION B: Static API key (simpler for local dev or non-Vercel CI)
#   Get a key at https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# =============================================================================
# Optional
# =============================================================================
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
